# Data-Agent 环境变量配置
# 复制此文件为 .env 并填写实际值

# LLM API 配置
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai-proxy.org/v1
LLM_MODEL_NAME=gpt-4

# 数据库配置（Docker 环境使用服务名）
DB_META_HOST=mysql
DB_META_PORT=3306
DB_META_USER=atguigu
DB_META_PASSWORD=Atguigu.123
DB_META_DATABASE=meta

DB_DW_HOST=mysql
DB_DW_PORT=3306
DB_DW_USER=atguigu
DB_DW_PASSWORD=Atguigu.123
DB_DW_DATABASE=dw

# Qdrant 配置
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Elasticsearch 配置
ES_HOST=elasticsearch
ES_PORT=9200

# Embedding 服务配置
EMBEDDING_HOST=embedding
EMBEDDING_PORT=8080
